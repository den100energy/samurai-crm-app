# Samurai CRM — environment variables
# Скопируй в .env.local и заполни своими значениями.
# На проде (Beget VPS) положи те же переменные в .env.local рядом с запущенным Next.js.

# ── Supabase ─────────────────────────────────────────────────────────────────
# После переезда на self-hosted Supabase на Beget — URL и ключи возьми из его .env
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Базовый URL приложения ───────────────────────────────────────────────────
# На проде: https://crm.samurai.ru (или иной домен). Локально: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron ─────────────────────────────────────────────────────────────────────
# Секрет для защиты /api/cron/* endpoint'ов. Сгенерировать: openssl rand -hex 32
CRON_SECRET=

# ── Telegram боты ────────────────────────────────────────────────────────────
# CRM-бот (для тренеров/админов): @samurai_school_crm_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
# Опциональные чаты (если не задать — уведомления туда не летят)
TELEGRAM_FINANCE_CHAT_ID=
ADMIN_CHAT_ID=
FOUNDER_TELEGRAM_CHAT_ID=

# Клиент-бот (для родителей/учеников): @samuraihelp_bot
TELEGRAM_CLIENT_BOT_TOKEN=
TELEGRAM_CLIENT_BOT_USERNAME=samuraihelp_bot
NEXT_PUBLIC_TELEGRAM_CLIENT_BOT_USERNAME=samuraihelp_bot

# ── ВКонтакте (сообщество-бот) ───────────────────────────────────────────────
# Сообщество: vk.com/samuraischool1 (id 19630823)
# Токен сообщества — Управление → Работа с API → Создать ключ доступа
VK_GROUP_TOKEN=
VK_GROUP_ID=19630823
# Из настроек Callback API
VK_CONFIRMATION_CODE=
VK_CALLBACK_SECRET=
# Короткое имя сообщества (нужно публично — для ссылки vk.me/<short>?ref=TOKEN)
NEXT_PUBLIC_VK_GROUP_SHORT_NAME=samuraischool1

# ── Макс (бот) — Этап 3, пока не заполнять ──────────────────────────────────
MAX_BOT_TOKEN=
NEXT_PUBLIC_MAX_BOT_USERNAME=

# ── LLM (OpenRouter) ─────────────────────────────────────────────────────────
# Используется в /api/generate-program и /api/compare-surveys
OPENROUTER_API_KEY=

# ── Cloudinary (фото учеников и тренеров) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
